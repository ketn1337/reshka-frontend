{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./CLAUDE.md)",
      "Read(./docs/**)",
      "Read(./package.json)",
      "Read(./tsconfig.json)",
      "Read(./vite.config.ts)",
      "Read(./tailwind.config.js)",
      "Read(./postcss.config.js)",
      "Read(./index.html)",
      "Read(./src/**)",
      "Edit(./CLAUDE.md)",
      "Edit(./docs/**)",
      "Edit(./src/**)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(npm test)",
      "Bash(npm run test)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff *)"
    ],
    "ask": [
      "Edit(./package.json)",
      "Edit(./package-lock.json)",
      "Edit(./vite.config.ts)",
      "Edit(./tsconfig.json)",
      "Edit(./tailwind.config.js)",
      "Edit(./postcss.config.js)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm update *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git pull *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",
      "Read(./secret/**)",
      "Read(./credentials/**)",
      "Read(./tokens/**)",
      "Read(./private/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./node_modules/**)",
      "Read(./dist/**)",
      "Read(./build/**)",
      "Read(./coverage/**)",
      "Read(./.git/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./**/.env)",
      "Edit(./**/.env.*)",
      "Edit(./secrets/**)",
      "Edit(./secret/**)",
      "Edit(./credentials/**)",
      "Edit(./tokens/**)",
      "Edit(./private/**)",
      "Edit(./node_modules/**)",
      "Edit(./dist/**)",
      "Edit(./build/**)",
      "Edit(./coverage/**)",
      "Edit(./.git/**)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable"
  }
}
